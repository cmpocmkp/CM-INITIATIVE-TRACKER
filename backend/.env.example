# Copy to .env and fill. On Railway set these as service Variables.
DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DB"
AUTH_SECRET="long-random-string"
SUPERADMIN_USERNAME="superadmin"
SUPERADMIN_PASSWORD="change-me"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
DEPARTMENT_DEFAULT_PASSWORD="123456"
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD="16-char-app-password"
DIGEST_RECIPIENTS="a@x.com,b@y.com"
# WhatsApp Business Cloud API (optional — reminders/credentials via WhatsApp)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
PORT=4000
APP_URL="https://your-app.up.railway.app"
